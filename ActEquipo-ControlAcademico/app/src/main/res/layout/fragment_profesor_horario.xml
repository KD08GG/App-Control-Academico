<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Horario del profesor"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#7B1FA2"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/tvHorarioProfesorInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Aquí se mostrarán tus materias y horarios."
        android:textSize="14sp"
        android:textColor="#555555"
        android:layout_marginBottom="12dp" />

    <ProgressBar
        android:id="@+id/progressHorarioProfesor"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/tvSinHorarioProfesor"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No tienes materias asignadas."
        android:textSize="14sp"
        android:textColor="#777777"
        android:visibility="gone"
        android:layout_marginBottom="12dp" />

    <ListView
        android:id="@+id/listViewHorarioProfesor"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:dividerHeight="8dp" />

</LinearLayout>