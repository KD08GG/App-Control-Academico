<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_gray">

    <LinearLayout
        android:id="@+id/llHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/primary_blue"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvTituloAdmin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Panel Administrativo"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/white" />

        <TextView
            android:id="@+id/tvSubtituloAdmin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gestión de usuarios y académica"
            android:textSize="14sp"
            android:textColor="@color/light_blue"
            android:layout_marginTop="6dp" />
    </LinearLayout>

    <HorizontalScrollView
        android:id="@+id/hsvTabs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/llHeader"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingTop="18dp"
            android:paddingEnd="16dp"
            android:paddingBottom="10dp">

            <Button
                android:id="@+id/btnGestionUsuarios"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="Usuarios"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:backgroundTint="@color/secondary_blue"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:layout_marginEnd="12dp" />

            <Button
                android:id="@+id/btnGestionAcademica"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="Académica"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:backgroundTint="@color/success_green"
                android:paddingStart="20dp"
                android:paddingEnd="20dp" />
        </LinearLayout>
    </HorizontalScrollView>

    <LinearLayout
        android:id="@+id/llSectionInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/hsvTabs"
        android:orientation="vertical"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="6dp"
        android:background="@color/white"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvSeccionActualAdmin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sección actual"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_secondary" />

        <TextView
            android:id="@+id/tvNombreSeccionAdmin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gestión de Usuarios"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/fragmentContainerAdmin"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/llSectionInfo"
        android:layout_above="@+id/tvLogOut"
        android:layout_margin="16dp"
        android:background="@color/white" />

    <TextView
        android:id="@+id/tvLogOut"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="48dp"
        android:text="Log Out"
        android:textColor="@color/logout_red"
        android:textSize="14sp"
        android:textStyle="bold"
        android:clickable="true"
        android:focusable="true" />

</RelativeLayout>