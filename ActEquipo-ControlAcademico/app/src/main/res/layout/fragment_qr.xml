<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pase de Lista"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/primary_blue"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Selecciona tu materia"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="8dp"/>

        <Spinner
            android:id="@+id/spinnerMateriasQr"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="20dp"/>

        <Button
            android:id="@+id/btnGenerarQr"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Generar Código QR"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:backgroundTint="@color/primary_blue"
            android:textAllCaps="false"
            android:layout_marginBottom="24dp"/>

        <ProgressBar
            android:id="@+id/progressQr"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginBottom="16dp"/>

        <ImageView
            android:id="@+id/imgQr"
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:visibility="gone"
            android:background="@color/white"
            android:padding="12dp"
            android:elevation="4dp"/>

        <TextView
            android:id="@+id/tvInstruccionQr"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Muestra este código al profesor para registrar tu asistencia."
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:visibility="gone"/>

    </LinearLayout>
</ScrollView>